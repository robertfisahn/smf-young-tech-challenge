APP_NAME="SMF Young Tech Challenge"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
DB_DATABASE=/var/www/database/faktury.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ==========================================
# OCR & AI Configuration
# ==========================================

# Ścieżka do silnika Tesseract OCR
# Windows: "C:/Program Files/Tesseract-OCR/tesseract.exe"
# Docker / Linux: "tesseract"
TESSERACT_PATH="tesseract"

# Default AI Provider: "groq" (chmura) lub "ollama" (lokalny)
AI_PROVIDER=groq

# Groq API (darmowy, szybki)
# Klucz można wygenerować za darmo na: https://console.groq.com/keys
GROQ_API_KEY="your_groq_api_key_here"
GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"

# Ollama (lokalny model AI)
# Instalacja: https://ollama.com + ollama pull llama3.1
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL=llama3.1

VITE_APP_NAME="${APP_NAME}"
